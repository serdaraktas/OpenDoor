<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZKTEKO SC403"
                    android:textColor="#666666"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kapı Kontrolü"
                    android:textColor="#F0F0F0"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Status dot -->
            <TextView
                android:id="@+id/statusDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle"
                android:textColor="#444444" />

        </LinearLayout>

        <!-- Boşluk -->
        <View android:layout_width="match_parent" android:layout_height="40dp" />

        <!-- Kapı butonu -->
        <FrameLayout
            android:id="@+id/doorBtn"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/circle_btn"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔓"
                    android:textSize="48sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/btnLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KAPIYI AÇ"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"
                    android:gravity="center" />
            </LinearLayout>
        </FrameLayout>

        <!-- Log mesajı -->
        <TextView
            android:id="@+id/logMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Hazır"
            android:textColor="#666666"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:gravity="center" />

        <!-- Saat -->
        <TextView
            android:id="@+id/timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#444444"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1" />

        <!-- Boşluk -->
        <View android:layout_width="match_parent" android:layout_height="28dp" />

        <!-- Ayarlar toggle -->
        <Button
            android:id="@+id/settingsToggle"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="⚙ AYARLAR"
            android:textColor="#666666"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:fontFamily="monospace"
            android:background="@drawable/btn_outline"
            android:stateListAnimator="@null" />

        <!-- Ayarlar paneli -->
        <LinearLayout
            android:id="@+id/settingsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/settings_bg"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BAĞLANTI AYARLARI"
                android:textColor="#666666"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:layout_marginBottom="14dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CİHAZ IP" android:textColor="#555555" android:textSize="10sp"
                android:fontFamily="monospace" android:letterSpacing="0.15" />
            <EditText
                android:id="@+id/cfgHost"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="192.168.1.97"
                android:text="192.168.1.97"
                android:textColor="#F0F0F0"
                android:textColorHint="#333333"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:inputType="text"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="KULLANICI ADI" android:textColor="#555555" android:textSize="10sp"
                android:fontFamily="monospace" android:letterSpacing="0.15" />
            <EditText
                android:id="@+id/cfgUser"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="1"
                android:text="1"
                android:textColor="#F0F0F0"
                android:textColorHint="#333333"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:inputType="text"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ŞİFRE" android:textColor="#555555" android:textSize="10sp"
                android:fontFamily="monospace" android:letterSpacing="0.15" />
            <EditText
                android:id="@+id/cfgPass"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="1140"
                android:text="1140"
                android:textColor="#F0F0F0"
                android:textColorHint="#333333"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:inputType="textPassword"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/saveBtn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="KAYDET"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:background="@drawable/btn_accent"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
